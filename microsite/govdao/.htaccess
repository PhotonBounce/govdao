# Bypass WordPress rewrites — serve real files directly
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /govdao/
  # If the request maps to an actual file on disk, serve it and stop
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]
  # If the request maps to an actual directory, serve it and stop
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
</IfModule>

# APK MIME type so browsers download instead of refusing
AddType application/vnd.android.package-archive .apk

<Files "*.apk">
    ForceType application/vnd.android.package-archive
    Header set Content-Disposition "attachment"
    Header set X-Content-Type-Options "nosniff"
</Files>

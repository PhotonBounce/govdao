{
  "name": "govdao",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:gas": "REPORT_GAS=true hardhat test",
    "deploy:local": "hardhat run scripts/deploy.ts",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
    "clean": "hardhat clean",
    "export:manifest": "ts-node scripts/export-app-manifest.ts",
    "validate:google-play": "ts-node scripts/validate-google-play-release.ts",
    "validate:app-config": "ts-node scripts/validate-app-config.ts",
    "mobile:validate": "npm run mobile:check-manifest && npm run mobile:typecheck",
    "mobile:check-data": "npm --prefix apps/mobile run check:data",
    "mobile:check-session": "npm --prefix apps/mobile run check:session",
    "mobile:check-vote": "npm --prefix apps/mobile run check:vote",
    "mobile:check-chain": "npm --prefix apps/mobile run check:chain",
    "mobile:check-proposal": "npm --prefix apps/mobile run check:proposal",
    "mobile:check-create": "npm --prefix apps/mobile run check:create",
    "mobile:check-members": "npm --prefix apps/mobile run check:members",
    "mobile:check-motion": "npm --prefix apps/mobile run check:motion",
    "mobile:check-notifications": "npm --prefix apps/mobile run check:notifications",
    "mobile:check-delegate": "npm --prefix apps/mobile run check:delegate",
    "mobile:check-activity": "npm --prefix apps/mobile run check:activity",
    "release:google-play": "npm run mobile:validate && ts-node scripts/export-app-manifest.ts --output config/mobile-app.manifest.google-play.generated.json && ts-node scripts/validate-google-play-release.ts --manifest config/mobile-app.manifest.google-play.generated.json && ts-node scripts/validate-app-config.ts --manifest config/mobile-app.manifest.google-play.generated.json",
    "mobile:sync-manifest": "npm --prefix apps/mobile run sync:manifest",
    "mobile:check-manifest": "npm --prefix apps/mobile run check:manifest",
    "mobile:typecheck": "npm --prefix apps/mobile run typecheck",
    "mobile:start": "npm --prefix apps/mobile run start"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PhotonBounce/govdao.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/PhotonBounce/govdao/issues"
  },
  "homepage": "https://github.com/PhotonBounce/govdao#readme",
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.39",
    "chai": "^4.5.0",
    "ethers": "^6.16.0",
    "hardhat": "^2.28.6",
    "hardhat-gas-reporter": "^2.3.0",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1"
  }
}

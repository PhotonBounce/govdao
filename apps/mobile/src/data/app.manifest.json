{
  "app": {
    "name": "GOVDAO",
    "bundleId": "com.govdao.app",
    "version": "0.2.0",
    "environment": "sepolia",
    "distribution": {
      "channel": "google-play",
      "pricingModel": "subscription",
      "hostedServices": [
        "notifications",
        "search",
        "ipfs-pinning"
      ]
    }
  },
  "wallet": {
    "required": true,
    "supported": [
      "walletconnect",
      "coinbase-wallet",
      "injected"
    ]
  },
  "chain": {
    "id": 31337,
    "name": "localhost",
    "rpcUrl": "http://127.0.0.1:8545",
    "blockExplorer": "https://etherscan.io"
  },
  "contracts": {
    "memberRegistry": "0x0B306BF915C4d645ff596e518fAf3F9669b97016",
    "timelock": "0x959922bE3CAee4b8Cd9a407cc3ac1C251C2007B1",
    "governor": "0x9A9f2CCfdE556A7E9Ff0848998Aa4a0CFD8863AE",
    "treasury": "0x68B1D87F95878fE05B998F19b66F4baba5De1aed",
    "emergencyGuardian": "0x3Aa5ebB10DC797CAC828524e59A333d0A371443c"
  },
  "features": {
    "proposalFeed": true,
    "proposalCreation": true,
    "voting": true,
    "treasuryView": true,
    "pushNotifications": true,
    "biometricConfirm": true,
    "fiatOnramp": false
  },
  "services": {
    "metadataBaseUrl": "https://example.govdao.app/metadata",
    "indexerBaseUrl": "https://example.govdao.app/indexer",
    "notificationBaseUrl": "https://example.govdao.app/notifications",
    "mobileFeeds": {
      "proposalsPath": "/mobile/proposals",
      "motionsPath": "/mobile/motions",
      "treasuryPath": "/mobile/treasury",
      "guardianPath": "/mobile/guardian",
      "workspacePath": "/mobile/workspace",
      "membersPath": "/mobile/members"
    }
  },
  "support": {
    "website": "https://govdao.app",
    "email": "support@govdao.app",
    "legalName": "GOVDAO Labs",
    "privacyPolicyUrl": "https://govdao.app/privacy",
    "termsOfServiceUrl": "https://govdao.app/terms"
  },
  "governance": {
    "mode": "hybrid",
    "offchain": {
      "enabled": true,
      "provider": "govdao-control-plane",
      "apiBaseUrl": "https://example.govdao.app/offchain",
      "auth": [
        "passkey",
        "wallet-signature"
      ],
      "proposalStorage": "postgres+ipfs",
      "voteStorage": "postgres+merkle-anchoring",
      "voteAnchoringEnabled": true
    }
  },
  "experiences": {
    "primaryModuleId": "dao",
    "modules": [
      {
        "id": "dao",
        "title": "Governance",
        "kind": "dao",
        "enabled": true,
        "entryRoute": "/governance",
        "apiBaseUrl": "https://api.govdao.app/governance",
        "webUrl": "https://app.govdao.app/governance",
        "requiresAuth": true
      },
      {
        "id": "workspace",
        "title": "Workspace",
        "kind": "documents",
        "enabled": true,
        "entryRoute": "/workspace",
        "apiBaseUrl": "https://api.govdao.app/workspace",
        "webUrl": "https://app.govdao.app/workspace",
        "requiresAuth": true
      }
    ]
  },
  "release": {
    "android": {
      "applicationId": "com.govdao.app",
      "versionCode": 2,
      "track": "internal"
    },
    "listing": {
      "shortDescription": "Transparent governance for member-led organizations.",
      "fullDescription": "GOVDAO gives members a secure mobile interface for proposals, voting, treasury transparency, and emergency governance status.",
      "category": "business"
    }
  }
}

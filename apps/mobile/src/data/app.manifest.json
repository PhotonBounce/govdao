{
  "app": {
    "name": "GOVDAO",
    "bundleId": "com.govdao.app",
    "version": "0.2.0",
    "environment": "polygon",
    "distribution": {
      "channel": "google-play",
      "pricingModel": "subscription",
      "hostedServices": [
        "notifications",
        "search",
        "ipfs-pinning"
      ]
    }
  },
  "wallet": {
    "required": true,
    "supported": [
      "walletconnect",
      "coinbase-wallet",
      "injected"
    ]
  },
  "chain": {
    "id": 137,
    "name": "polygon",
    "rpcUrl": "https://polygon-mainnet.g.alchemy.com/v2/nTxCkb9NGgPk3FUXMlDsC",
    "blockExplorer": "https://polygonscan.com"
  },
  "contracts": {
    "memberRegistry": "0xaFBAB7016b1c17A2099De448aC2f74bA563b2Aaa",
    "timelock": "0x72B35C420259a2330adE3293E1fEFd79cf0244E5",
    "governor": "0x85A460c2992f1928612D027d1D860543B00f921f",
    "treasury": "0x707567E47F1a858ca152AB966A6dAE3975143Ee5",
    "emergencyGuardian": "0xe4E518e58fEa19B0C8398833607CD82c3feb342d"
  },
  "features": {
    "proposalFeed": true,
    "proposalCreation": true,
    "voting": true,
    "treasuryView": true,
    "pushNotifications": true,
    "biometricConfirm": true,
    "fiatOnramp": false,
    "plan": "premium"
  },
  "services": {
    "metadataBaseUrl": "https://photon-bounce.com/govdao/api/metadata",
    "indexerBaseUrl": "https://photon-bounce.com/govdao/api/indexer",
    "notificationBaseUrl": "https://photon-bounce.com/govdao/api/notifications",
    "mobileFeeds": {
      "proposalsPath": "/mobile/proposals",
      "motionsPath": "/mobile/motions",
      "treasuryPath": "/mobile/treasury",
      "guardianPath": "/mobile/guardian",
      "workspacePath": "/mobile/workspace",
      "membersPath": "/mobile/members"
    }
  },
  "support": {
    "website": "https://govdao.app",
    "email": "support@govdao.app",
    "legalName": "GOVDAO Labs",
    "privacyPolicyUrl": "https://govdao.app/privacy",
    "termsOfServiceUrl": "https://govdao.app/terms"
  },
  "governance": {
    "mode": "hybrid",
    "offchain": {
      "enabled": true,
      "provider": "govdao-control-plane",
      "apiBaseUrl": "fixture://govdao",
      "auth": [
        "passkey",
        "wallet-signature"
      ],
      "proposalStorage": "postgres+ipfs",
      "voteStorage": "postgres+merkle-anchoring",
      "voteAnchoringEnabled": true
    }
  },
  "experiences": {
    "primaryModuleId": "dao",
    "modules": [
      {
        "id": "dao",
        "title": "Governance",
        "kind": "dao",
        "enabled": true,
        "entryRoute": "/governance",
        "apiBaseUrl": "fixture://govdao",
        "webUrl": "https://app.govdao.app/governance",
        "requiresAuth": true
      },
      {
        "id": "workspace",
        "title": "Workspace",
        "kind": "documents",
        "enabled": true,
        "entryRoute": "/workspace",
        "apiBaseUrl": "fixture://govdao",
        "webUrl": "https://app.govdao.app/workspace",
        "requiresAuth": true
      }
    ]
  },
  "release": {
    "android": {
      "applicationId": "com.govdao.app",
      "versionCode": 2,
      "track": "internal"
    },
    "listing": {
      "shortDescription": "Transparent governance for member-led organizations.",
      "fullDescription": "GOVDAO gives members a secure mobile interface for proposals, voting, treasury transparency, and emergency governance status.",
      "category": "business"
    }
  }
}

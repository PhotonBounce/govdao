{
  "app": {
    "name": "GOVDAO",
    "bundleId": "com.govdao.app",
    "version": "0.2.0",
    "environment": "polygon",
    "distribution": {
      "channel": "google-play",
      "pricingModel": "subscription",
      "hostedServices": [
        "notifications",
        "search",
        "ipfs-pinning"
      ]
    }
  },
  "wallet": {
    "required": true,
    "supported": [
      "walletconnect",
      "coinbase-wallet",
      "injected"
    ]
  },
  "chain": {
    "id": 137,
    "name": "polygon",
    "rpcUrl": "https://polygon-rpc.com",
    "blockExplorer": "https://polygonscan.com"
  },
  "contracts": {
    "memberRegistry": "0x43fb0141274624AAeD88571736c25dc69c406A92",
    "timelock": "0x0e6327b1106BCA47E31E3Ca25ebe29414721f274",
    "governor": "0x279289Aa3b317a2B6c5C59890231DAa36efD69a8",
    "treasury": "0xF08cC18174e543DFf8d6bAfcaFd35a278b21Bea9",
    "emergencyGuardian": "0x84C634Bc6369E0f358d8a42d55BA63Aebce96D49"
  },
  "features": {
    "proposalFeed": true,
    "proposalCreation": true,
    "voting": true,
    "treasuryView": true,
    "pushNotifications": true,
    "biometricConfirm": true,
    "fiatOnramp": false,
    "plan": "premium"
  },
  "services": {
    "metadataBaseUrl": "https://example.govdao.app/metadata",
    "indexerBaseUrl": "https://example.govdao.app/indexer",
    "notificationBaseUrl": "https://example.govdao.app/notifications",
    "mobileFeeds": {
      "proposalsPath": "/mobile/proposals",
      "motionsPath": "/mobile/motions",
      "treasuryPath": "/mobile/treasury",
      "guardianPath": "/mobile/guardian",
      "workspacePath": "/mobile/workspace",
      "membersPath": "/mobile/members"
    }
  },
  "support": {
    "website": "https://govdao.app",
    "email": "support@govdao.app",
    "legalName": "GOVDAO Labs",
    "privacyPolicyUrl": "https://govdao.app/privacy",
    "termsOfServiceUrl": "https://govdao.app/terms"
  },
  "governance": {
    "mode": "hybrid",
    "offchain": {
      "enabled": true,
      "provider": "govdao-control-plane",
      "apiBaseUrl": "fixture://govdao",
      "auth": [
        "passkey",
        "wallet-signature"
      ],
      "proposalStorage": "postgres+ipfs",
      "voteStorage": "postgres+merkle-anchoring",
      "voteAnchoringEnabled": true
    }
  },
  "experiences": {
    "primaryModuleId": "dao",
    "modules": [
      {
        "id": "dao",
        "title": "Governance",
        "kind": "dao",
        "enabled": true,
        "entryRoute": "/governance",
        "apiBaseUrl": "fixture://govdao",
        "webUrl": "https://app.govdao.app/governance",
        "requiresAuth": true
      },
      {
        "id": "workspace",
        "title": "Workspace",
        "kind": "documents",
        "enabled": true,
        "entryRoute": "/workspace",
        "apiBaseUrl": "fixture://govdao",
        "webUrl": "https://app.govdao.app/workspace",
        "requiresAuth": true
      }
    ]
  },
  "release": {
    "android": {
      "applicationId": "com.govdao.app",
      "versionCode": 2,
      "track": "internal"
    },
    "listing": {
      "shortDescription": "Transparent governance for member-led organizations.",
      "fullDescription": "GOVDAO gives members a secure mobile interface for proposals, voting, treasury transparency, and emergency governance status.",
      "category": "business"
    }
  }
}

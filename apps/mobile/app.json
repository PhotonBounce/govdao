{
  "expo": {
    "name": "GOVDAO",
    "slug": "govdao-mobile",
    "scheme": "govdao",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0d1a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.govdao.app"
    },
    "android": {
      "package": "com.govdao.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f3efe3"
      },
      "permissions": []
    },
    "web": {
      "bundler": "metro"
    }
  }
}

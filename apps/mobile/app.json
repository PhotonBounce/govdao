{
  "expo": {
    "name": "GOVDAO",
    "slug": "govdao-mobile",
    "scheme": "govdao",
    "version": "0.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0d1a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.govdao.app"
    },
    "android": {
      "package": "com.govdao.app",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f3efe3"
      },
      "permissions": []
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "revenueCatApiKey": ""
    },
    "plugins": [
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-7584543130600454~4392371847",
          "iosAppId": "ca-app-pub-7584543130600454~4392371847"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#c98340"
        }
      ]
    ]
  }
}

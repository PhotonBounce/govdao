{
  "_comment": "Copy to credentials.json (gitignored) for an EAS LOCAL-credentials build. Points EAS at the keystore made by scripts/generate-keystore.sh. Do NOT commit the real credentials.json or the keystore.",
  "android": {
    "keystore": {
      "keystorePath": "../../secrets/govdao-upload.keystore",
      "keystorePassword": "$KEYSTORE_PASSWORD",
      "keyAlias": "govdao-upload",
      "keyPassword": "$KEY_PASSWORD"
    }
  }
}
